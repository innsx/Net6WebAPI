{
  //2 ways you can configure Serilog in ASP.NET Core: 1Fluent API & 2Serilog configuration system
  //OPTION #2: Here is a Serilog configuration system
  //docs tutorial: https://learnwithinderjeet.com/blog/write-error-logs-into-sql-server-using-serilog/
  "Serilog": {
    "Using": [
      "Serilog.Sinks.MSSqlServer", //option: Write logs to SQL Server
      "Serilog.Sinks.Console", //option: Write logs to console
      "Serilog.Sinks.File", //option: Write logs to file
      "Serilog.Sinks.Debug", //option: Write logs to debug console
      "Serilog.Sinks.Seq" //option: Write logs to Seq  "dotnet add package Serilog.Sinks.Seq --version 9.0.0" then Navigate to localhost:8081 to view structured logs in real time.
      //"Serilog.Enrichers.Environment", //option: 
      //"Serilog.Enrichers.Thread", //option: 
      //"Serilog.Enrichers.Process", //option: 
      //"Serilog.Exceptions" //option: 
    ],
    "MinimumLevel": {
      "Default": "Warning",
      "Override": {
        "System": "Error", //OVERALL System Overide option
        "Microsoft": "Error" //OVERALL Microsoft Overide option
        //"Microsoft.AspNetCore.Hosting.Diagnostics": "Error", //Overide specific Microsoft option
        //"Microsoft.Hosting.Lifetime": "Information", //Overide specific Microsoft option
        //"Microsoft.EntityFrameworkCore.Database.Command": "Warning", //Overide specific Microsoft option
        //"System.Net.Http.HttpClient": "Warning" //Overide specific System option
      }
    },
    "WriteTo": [
      {
        "Name": "MSSqlServer",
        "Args": {
          "connectionString": "Server=DESKTOP-KQ86VHG\\SQLEXPRESS;Database=TestDb;Trusted_Connection=true;TrustServerCertificate=True;MultipleActiveResultSets=true;",
          "sinkOptionsSection": {
            "tableName": "SerilogEvents",
            "schemaName": "dbo",
            "autoCreateSqlTable": true //default is false
          },
          "restrictedToMinimumLevel": "Error",
          "columnOptionsSection": {
            "clusteredColumnstoreIndex": false,
            "primaryKeyColumnName": "Id",
            "removeStandardColumns": [ "MessageTemplate", "Properties", "LogEvent" ],            
            "id": { "nonClusteredIndex": true },
            "timeStamp": {
              "columnName": "Timestamp",
              //"columnName": "TimestampUtc",
              "convertToUtc": false
              //"convertToUtc": true
            }
          }
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/log-.txt",
          "rollingInterval": "Day"
          //"rollOnFileSizeLimit": true, //Option
          //"fileSizeLimitBytes": 104857600, //Option
          //"retainedFileCountLimit": 14, //Option
          //"formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact" //Option
        }
      },
      {
        "Name": "Console"
      },
      {
        "Name": "Debug"
      },
      {
        "Name": "Seq",
        "Args": { "serverUrl": "http://localhost:5341" }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId"
    ]
  },
  //"Logging": {
  //  "LogLevel": {
  //    "Default": "Information",
  //    "Microsoft.AspNetCore": "Warning"
  //  }
